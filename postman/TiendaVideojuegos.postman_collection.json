{
  "info": {
    "name": "Tienda Videojuegos - Microservicios",
    "description": "Coleccion basica para probar los endpoints principales a traves del API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Swagger - UI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/swagger-ui/index.html"
      }
    },
    {
      "name": "Swagger - UI config",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/v3/api-docs/swagger-config"
      }
    },
    {
      "name": "Swagger - OpenAPI Videojuegos",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/videojuegos/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Usuarios",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/usuarios/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Auth",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Carrito",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carrito/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Pagos",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/pagos/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Pedidos",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/pedidos/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Resenas",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/resenas/v3/api-docs"
      }
    },
    {
      "name": "Swagger - OpenAPI Inventario",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventario/v3/api-docs"
      }
    },
    {
      "name": "Videojuegos - listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/videojuegos"
      }
    },
    {
      "name": "Videojuegos - buscar por precio",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/videojuegos/buscar?precioMin=10000&precioMax=30000"
      }
    },
    {
      "name": "Videojuegos - buscar por plataforma PC",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/videojuegos/buscar?plataforma=PC"
      }
    },
    {
      "name": "Videojuegos - crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Hades\",\n  \"categoria\": \"Roguelike\",\n  \"precio\": 14990,\n  \"plataforma\": \"PC\"\n}"
        },
        "url": "{{baseUrl}}/videojuegos"
      }
    },
    {
      "name": "Errores - plataforma invalida videojuego",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Prueba Plataforma Invalida\",\n  \"categoria\": \"Test\",\n  \"precio\": 10000,\n  \"plataforma\": \"Game Boy\"\n}"
        },
        "url": "{{baseUrl}}/videojuegos"
      }
    },
    {
      "name": "Usuarios - listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/usuarios"
      }
    },
    {
      "name": "Auth - login demo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"correo\": \"jesus@tiendajuegos.cl\",\n  \"password\": \"cliente123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body.token) {",
              "  pm.collectionVariables.set('token', body.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - crear cuenta valida",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Postman\",\n  \"apellido\": \"Demo\",\n  \"correo\": \"postman{{$timestamp}}@tiendajuegos.cl\",\n  \"telefono\": \"+56912345678\",\n  \"direccion\": \"Santiago\",\n  \"rol\": \"CLIENTE\",\n  \"password\": \"12345\"\n}"
        },
        "url": "{{baseUrl}}/auth/registro"
      }
    },
    {
      "name": "Auth - error password corta",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Postman\",\n  \"apellido\": \"Error\",\n  \"correo\": \"postman.error{{$timestamp}}@tiendajuegos.cl\",\n  \"telefono\": \"+56912345678\",\n  \"direccion\": \"Santiago\",\n  \"rol\": \"CLIENTE\",\n  \"password\": \"1234\"\n}"
        },
        "url": "{{baseUrl}}/auth/registro"
      }
    },
    {
      "name": "Carrito - usuario 2",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carrito/usuario/2"
      }
    },
    {
      "name": "Carrito - resumen usuario 2",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carrito/usuario/2/resumen"
      }
    },
    {
      "name": "Carrito - agregar item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuarioId\": 2,\n  \"videojuegoId\": 1,\n  \"cantidad\": 1\n}"
        },
        "url": "{{baseUrl}}/carrito"
      }
    },
    {
      "name": "Pagos - listar",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/pagos"
      }
    },
    {
      "name": "Pedidos - listar con usuario",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/pedidos"
      }
    },
    {
      "name": "Resenas - listar con usuario",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/resenas"
      }
    },
    {
      "name": "Inventario - listar con videojuego",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventario"
      }
    },
    {
      "name": "Inventario - bajo stock",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventario/bajo-stock"
      }
    },
    {
      "name": "Errores - validacion videojuego",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"\",\n  \"categoria\": \"\",\n  \"precio\": -1,\n  \"plataforma\": \"\"\n}"
        },
        "url": "{{baseUrl}}/videojuegos"
      }
    }
  ]
}
